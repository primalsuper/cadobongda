
---
import MainLayout from "../layouts/MainLayout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<MainLayout
  title="Cadobongda - Teknologi, AI, Game & Finance"
  description="Portal berita teknologi, AI, finance dan game modern."
  canonical="https://cadobongda.org/"
>

<main class="container">
  <div class="layout">

    <section>

      <article class="card">
        <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=1200&auto=format&fit=crop" alt="AI" />

        <div class="card-content">
          <div class="meta">Teknologi • 20 Mei 2026</div>

          <h2>
            Tren AI 2026 Mengubah Industri Teknologi Global
          </h2>

          <p>
            Cadobongda menghadirkan berita teknologi, AI, finance dan game
            dengan struktur ultra SEO dan performa cepat.
          </p>
        </div>
      </article>

      <article class="card">
        <div class="card-content">
          <div class="meta">Finance</div>

          <h2>Pergerakan Saham Teknologi Hari Ini</h2>

          <p>
            Update finance modern dengan struktur AMP-like ultra ringan.
          </p>
        </div>
      </article>

    </section>

    <Sidebar />

  </div>
</main>

</MainLayout>
